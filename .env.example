# Eyetor — Environment Variables
# Copy this file to .env and fill in your values

# OpenRouter API key (required for OpenRouter provider)
OPENROUTER_API_KEY=

# llama.cpp server API key (optional, only if auth is enabled)
LLAMACPP_API_KEY=

# Google Gemini API key (required for Gemini provider — LLM and/or image generation)
GEMINI_API_KEY=

# Telegram bot token (required for Telegram channel)
TELEGRAM_BOT_TOKEN=

# Telegram allowed user (numeric chat_id, get it from @userinfobot)
TELEGRAM_ALLOWED_USER=

# GitHub token (required for github MCP server)
GITHUB_TOKEN=
